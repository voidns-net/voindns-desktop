{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoidNS Client",
  "version": "0.1.0",
  "identifier": "net.voidns.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoidNS Client",
        "width": 350,
        "height": 540,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/voidns-service",
      "binaries/voidns"
    ],
    "linux": {
      "rpm": {
        "files": {
          "/usr/lib/systemd/system/voidns.service": "packaging/voidns.service"
        },
        "postInstallScript": "packaging/rpm/postinstall.sh",
        "preRemoveScript": "packaging/rpm/preremove.sh",
        "postRemoveScript": "packaging/rpm/postremove.sh"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "packaging/windows/hooks.nsh"
      }
    }
  }
}
