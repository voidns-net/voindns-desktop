{
  "name": "voidns-e2e",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Universal (Windows + Linux RPM) end-to-end installer test: install -> service up -> connect to a mock DoH -> DNS query -> assert it reached the mock.",
  "scripts": {
    "e2e": "tsx src/run.ts",
    "e2e:install": "tsx src/run.ts --mode install",
    "e2e:dev": "tsx src/run.ts --mode dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dns-packet": "^5.6.1",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/dns-packet": "^5.6.5",
    "@types/node": "^22.10.0",
    "@types/node-forge": "^1.3.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
